# Standard Notes - Encrypted notes server
# Copy to app.env and customize

# Timezone
TZ=America/New_York

# Hostname / Domain
BASE_HOST_NAME=$HOSTNAME
BASE_DOMAIN_NAME=example.com

# Database (MariaDB)
DB_CREATE_DATABASE_NAME=standardnotes
DB_USER_NAME=standardnotes
DB_USER_PASS=changeme_db_password
DB_ADMIN_PASS=changeme_admin_password

# Redis
REDIS_PORT=6379

# App secret (min 32 chars)
APP_SECRET_KEY=changeme_secret_key_min_32_chars
